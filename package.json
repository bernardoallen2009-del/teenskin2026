{
  "name": "teensskin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c \"#A678BA,#FF9AAF\" \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "next dev -p 3000",
    "dev:api": "tsx watch server/index.ts",
    "build": "npm run build:web && npm run build:api",
    "build:web": "next build",
    "build:api": "tsc -p tsconfig.server.json",
    "start:web": "next start -p 3000",
    "start:api": "node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@prisma/client": "^7.1.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "5.2.1",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^12.23.26",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.561.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stripe": "^20.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.9",
    "prisma": "^7.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.15",
    "shell-quote": "1.8.4"
  }
}
